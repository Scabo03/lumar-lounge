# Parametri Apple del progetto Lumar Lounge.
# app_identifier è FISSO: definisce *questo* progetto e non va letto da env, per
# non farsi sovrascrivere da un file di credenziali multi-progetto sourcato.
# apple_id e team_id sono a livello di account (condivisi) e accettano override.

app_identifier("com.scabo.lumarlounge")
apple_id(ENV["APPLE_ID"]     || "scabo@icloud.com")
team_id(ENV["APPLE_TEAM_ID"] || "D2KQYQ8YU8")
