# Fastfile — Lumar Lounge
#
# Due lane:
#   • setup_signing    — inizializza / riallinea i certificati via Match (appstore)
#   • testflight_upload — build, archive, export e upload TestFlight in un colpo solo
#
# La pipeline di build usa `xcodebuild` diretto (archive + export, senza
# -destination, piattaforma device forzata) e `xcrun altool` per l'upload: è la
# pipeline collaudata sugli altri progetti iOS dell'utente. Non si usa gym() di
# proposito, perché su progetti reali questo flusso si è dimostrato più affidabile.

require "fileutils"
require "base64"

default_platform(:ios)

# ── Config ────────────────────────────────────────────────────────────────────
# Identità del progetto: FISSA, non da env. Le credenziali condivise vivono in un
# file env multi-progetto (es. ~/Developer/private_keys/scabo_deploy.env) che
# porta un APP_IDENTIFIER / MATCH_GIT_URL di un ALTRO progetto: pinnandoli qui
# evitiamo che match colpisca l'app o il repo certificati sbagliati.
APP_IDENTIFIER = "com.scabo.lumarlounge"
CERTS_GIT_URL  = "https://github.com/Scabo03/lumar-lounge-certs.git"
# Valori a livello di account, condivisi tra i progetti: ok leggerli da env.
TEAM_ID        = ENV["APPLE_TEAM_ID"] || "D2KQYQ8YU8"
SCHEME         = "LumarLounge"
PROJECT_ROOT   = File.expand_path("..", __dir__)
PROJECT_PATH   = File.join(PROJECT_ROOT, "LumarLounge.xcodeproj")
BUILD_DIR      = File.join(PROJECT_ROOT, "build")
ARCHIVE_PATH   = File.join(BUILD_DIR, "LumarLounge.xcarchive")
EXPORT_PATH    = File.join(BUILD_DIR, "export")
PROFILE_NAME   = "match AppStore #{APP_IDENTIFIER}"

# ── Helper: App Store Connect API key ────────────────────────────────────────
# Usa APP_STORE_CONNECT_API_KEY_CONTENT (contenuto del .p8, base64 o PEM) se
# presente, altrimenti il file puntato da APP_STORE_CONNECT_API_KEY_PATH
# (default ~/AuthKey.p8).
def asc_api_key
  key_id    = ENV["APP_STORE_CONNECT_API_KEY_ID"]
  issuer_id = ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"]

  if (content = ENV["APP_STORE_CONNECT_API_KEY_CONTENT"]) && !content.empty?
    app_store_connect_api_key(
      key_id:                key_id,
      issuer_id:             issuer_id,
      key_content:           content,
      is_key_content_base64: !content.include?("BEGIN PRIVATE KEY"),
      in_house:              false,
    )
  else
    path = File.expand_path(ENV["APP_STORE_CONNECT_API_KEY_PATH"] || "~/AuthKey.p8")
    UI.user_error!("API key non trovata: #{path}. Imposta APP_STORE_CONNECT_API_KEY_PATH o APP_STORE_CONNECT_API_KEY_CONTENT.") unless File.exist?(path)
    app_store_connect_api_key(
      key_id:       key_id,
      issuer_id:    issuer_id,
      key_filepath: path,
      in_house:     false,
    )
  end
end

# Materializza la .p8 dove `xcrun altool` la cerca:
# ~/.appstoreconnect/private_keys/AuthKey_<KEYID>.p8
def ensure_altool_key
  key_id = ENV["APP_STORE_CONNECT_API_KEY_ID"]
  dir    = File.expand_path("~/.appstoreconnect/private_keys")
  FileUtils.mkdir_p(dir)
  dest = File.join(dir, "AuthKey_#{key_id}.p8")
  return dest if File.exist?(dest)

  if (content = ENV["APP_STORE_CONNECT_API_KEY_CONTENT"]) && !content.empty?
    data = content.include?("BEGIN PRIVATE KEY") ? content : Base64.decode64(content)
    File.write(dest, data)
  else
    src = File.expand_path(ENV["APP_STORE_CONNECT_API_KEY_PATH"] || "~/AuthKey.p8")
    UI.user_error!("API key non trovata: #{src}") unless File.exist?(src)
    FileUtils.cp(src, dest)
  end
  dest
end

# match mappa automaticamente l'env APP_STORE_CONNECT_API_KEY_PATH sull'opzione
# `api_key_path`, che va in conflitto con l'`api_key` (hash) che gli passiamo.
# Togliamo temporaneamente quell'env attorno alla chiamata a match e la
# ripristiniamo dopo (serve ad altool nello step di upload).
def without_api_key_path_env
  saved = ENV.delete("APP_STORE_CONNECT_API_KEY_PATH")
  yield
ensure
  ENV["APP_STORE_CONNECT_API_KEY_PATH"] = saved if saved
end

platform :ios do
  # ── Lane: setup_signing ────────────────────────────────────────────────────
  # Inizializza (prima volta) o riallinea i certificati di distribuzione e il
  # provisioning profile App Store per com.scabo.lumarlounge, li cifra con
  # MATCH_PASSWORD e li pusha su lumar-lounge-certs.
  #
  # Eseguire su una macchina nuova per recuperare i certificati con un solo comando.
  desc "Inizializza/riallinea i certificati di distribuzione via Match (App Store)"
  lane :setup_signing do
    api_key = asc_api_key
    without_api_key_path_env do
      match(
        type:           "appstore",
        app_identifier: APP_IDENTIFIER,
        git_url:        CERTS_GIT_URL,
        storage_mode:   "git",
        team_id:        TEAM_ID,
        api_key:        api_key,
        readonly:       false,
      )
    end
    UI.success("Certificati e provisioning profile App Store allineati su #{CERTS_GIT_URL}")
  end

  # ── Lane: testflight_upload ────────────────────────────────────────────────
  # Build → archive → export → upload TestFlight in un colpo solo.
  desc "Build, archive, export e upload su TestFlight"
  lane :testflight_upload do
    # 1. Certificati in sola lettura (devono già esistere nel repo certs).
    api_key = asc_api_key
    without_api_key_path_env do
      match(
        type:           "appstore",
        app_identifier: APP_IDENTIFIER,
        git_url:        CERTS_GIT_URL,
        storage_mode:   "git",
        team_id:        TEAM_ID,
        api_key:        api_key,
        readonly:       true,
      )
    end

    FileUtils.rm_rf(BUILD_DIR)
    FileUtils.mkdir_p(BUILD_DIR)

    # 2. Archive — xcodebuild diretto, niente -destination, piattaforma device.
    sh(
      "xcodebuild", "archive",
      "-project",      PROJECT_PATH,
      "-scheme",       SCHEME,
      "-configuration", "Release",
      "-archivePath",  ARCHIVE_PATH,
      "SUPPORTED_PLATFORMS=iphoneos",
      "SUPPORTS_MACCATALYST=NO",
      "DEVELOPMENT_TEAM=#{TEAM_ID}",
      "CODE_SIGN_STYLE=Manual",
      "CODE_SIGN_IDENTITY=Apple Distribution",
      "PROVISIONING_PROFILE_SPECIFIER=#{PROFILE_NAME}",
    )

    # 3. Export dell'IPA firmato per l'App Store.
    export_plist = File.join(BUILD_DIR, "ExportOptions.plist")
    File.write(export_plist, <<~PLIST)
      <?xml version="1.0" encoding="UTF-8"?>
      <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
      <plist version="1.0">
      <dict>
        <key>method</key><string>app-store</string>
        <key>teamID</key><string>#{TEAM_ID}</string>
        <key>signingStyle</key><string>manual</string>
        <key>provisioningProfiles</key>
        <dict>
          <key>#{APP_IDENTIFIER}</key><string>#{PROFILE_NAME}</string>
        </dict>
        <key>uploadSymbols</key><true/>
        <key>destination</key><string>export</string>
      </dict>
      </plist>
    PLIST

    sh(
      "xcodebuild", "-exportArchive",
      "-archivePath",        ARCHIVE_PATH,
      "-exportPath",         EXPORT_PATH,
      "-exportOptionsPlist", export_plist,
    )

    # 4. Upload su TestFlight con altool + API Key.
    ipa = Dir.glob(File.join(EXPORT_PATH, "*.ipa")).first
    UI.user_error!("Nessun .ipa prodotto in #{EXPORT_PATH}") unless ipa
    ensure_altool_key
    sh(
      "xcrun", "altool", "--upload-app",
      "-f", ipa,
      "-t", "ios",
      "--apiKey",    ENV["APP_STORE_CONNECT_API_KEY_ID"],
      "--apiIssuer", ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
    )
    UI.success("Upload TestFlight completato: #{File.basename(ipa)}")
  end
end
