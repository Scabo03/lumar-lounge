# Template OPZIONALE delle credenziali per le lane Fastlane.
#
# Su questa macchina i segreti condivisi tra i progetti iOS vivono già in:
#   ~/Developer/private_keys/scabo_deploy.env
# Il flusso normale è quindi sourcare quel file e lanciare la lane:
#   source ~/Developer/private_keys/scabo_deploy.env
#   bundle exec fastlane testflight_upload
#
# L'identità del progetto (APP_IDENTIFIER e repo certificati) è FISSA in
# Appfile/Matchfile/Fastfile, quindi il fatto che il file condiviso porti i
# valori di un altro progetto (scabopdf) è innocuo: vengono ignorati.
#
# Se preferisci un file locale dedicato, copia questo in `fastlane/.env`
# (gitignorato) e riempi i segreti. Fastlane carica fastlane/.env in automatico.

# Segreti a livello di account (condivisi tra i progetti)
APP_STORE_CONNECT_API_KEY_ID=MGW9GC97HV
APP_STORE_CONNECT_API_KEY_ISSUER_ID=eb059a17-fd00-46e7-8a8f-809e91ad80cc
APP_STORE_CONNECT_API_KEY_PATH=$HOME/Developer/private_keys/AuthKey_MGW9GC97HV.p8
# In alternativa al path, il contenuto del .p8 (PEM o base64):
# APP_STORE_CONNECT_API_KEY_CONTENT=
APPLE_TEAM_ID=D2KQYQ8YU8
APPLE_ID=scabo@icloud.com
MATCH_PASSWORD=

# Solo in CI (in locale il push al repo certs passa per il keychain):
# MATCH_GIT_BASIC_AUTHORIZATION=

# Nota: APP_IDENTIFIER e MATCH_GIT_URL NON vanno messi qui — sono pinnati nel
# codice Fastlane su com.scabo.lumarlounge / lumar-lounge-certs.
